{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@action-js/auth": ["packages/auth/src/index.ts"],
      "@action-js/cli": ["packages/cli/src/index.ts"],
      "@action-js/client": ["packages/client/src/index.ts"],
      "@action-js/core": ["packages/core/src/index.ts"],
      "@action-js/drizzle": ["packages/drizzle/src/index.ts"],
      "@action-js/jobs": ["packages/jobs/src/index.ts"],
      "@action-js/node": ["packages/node/src/index.ts"],
      "@action-js/openapi": ["packages/openapi/src/index.ts"],
      "@action-js/prisma": ["packages/prisma/src/index.ts"],
      "@action-js/redis": ["packages/redis/src/index.ts"],
      "@action-js/testing": ["packages/testing/src/index.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "types": ["node"]
  }
}
