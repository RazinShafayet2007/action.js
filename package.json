{
  "name": "action-js",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev --parallel",
    "lint": "oxlint . --ignore-pattern dist --ignore-pattern coverage --ignore-pattern packages/cli/.tmp-cli-*",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "oxlint": "latest",
    "turbo": "^2.0.12",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
